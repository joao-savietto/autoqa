# Django
DEBUG=true
SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
ALLOWED_HOSTS=localhost,127.0.0.1,web,0.0.0.0

# Database (SQLite - local only)
DATABASE_URL=sqlite:///db.sqlite3

# CORS (not needed for local-only, but included for completeness)
CORS_ALLOWED_ORIGINS=

# Chrome container connection
# Use "localhost" for local dev, "chrome" for Docker (overridden in docker-compose.yml)
CHROME_HOST=localhost
CHROME_DEBUG_PORT=9222

# MCP Server
MCP_API_URL=http://127.0.0.1:8000
MCP_API_KEY=
